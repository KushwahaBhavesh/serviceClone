generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String           @id @default(cuid())
  email               String?          @unique
  phone               String?          @unique
  name                String?
  avatarUrl           String?          @map("avatar_url")
  passwordHash        String?          @map("password_hash")
  role                UserRole         @default(CUSTOMER)
  status              UserStatus       @default(PENDING_VERIFICATION)
  authProvider        AuthProvider     @default(EMAIL) @map("auth_provider")
  googleId            String?          @unique @map("google_id")
  appleId             String?          @unique @map("apple_id")
  onboardingCompleted Boolean          @default(false) @map("onboarding_completed")
  locationName        String?          @map("location_name")
  latitude            Float?
  longitude           Float?
  pushToken           String?          @map("push_token")
  walletBalance       Float            @default(0) @map("wallet_balance")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  lastLoginAt         DateTime?        @map("last_login_at")
  addresses           Address[]
  agentProfile        Agent?
  bookings            Booking[]        @relation("CustomerBookings")
  merchantBookings    Booking[]        @relation("MerchantBookings")
  merchantProfile     MerchantProfile?
  otpCodes            OtpCode[]
  refreshTokens       RefreshToken[]
  reviews             Review[]
  notifications       Notification[]
  sentMessages        Message[]
  chatParticipations  ChatParticipant[]
  walletTransactions  WalletTransaction[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  userId    String?  @map("user_id")
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, code])
  @@index([userId])
  @@map("otp_codes")
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  iconUrl     String?    @map("icon_url")
  imageUrl    String?    @map("image_url")
  sortOrder   Int        @default(0) @map("sort_order")
  isActive    Boolean    @default(true) @map("is_active")
  parentId    String?    @map("parent_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  services    Service[]

  @@index([parentId])
  @@index([slug])
  @@map("categories")
}

model Service {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  description      String?
  imageUrl         String?           @map("image_url")
  basePrice        Float             @map("base_price")
  unit             String            @default("per_visit")
  duration         Int               @default(60)
  isActive         Boolean           @default(true) @map("is_active")
  categoryId       String            @map("category_id")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  bookingItems     BookingItem[]
  merchantServices MerchantService[]
  category         Category          @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([slug])
  @@map("services")
}

model MerchantProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique @map("user_id")
  businessName       String             @map("business_name")
  businessCategory   String?            @map("business_category")
  description        String?
  logoUrl            String?            @map("logo_url")
  coverImageUrl      String?            @map("cover_image_url")
  phone              String?
  address            String?
  city               String?
  state              String?
  zipCode            String?            @map("zip_code")
  latitude           Float?
  longitude          Float?
  serviceRadius      Float              @default(10) @map("service_radius")
  rating             Float              @default(0)
  totalReviews       Int                @default(0) @map("total_reviews")
  isVerified         Boolean            @default(false) @map("is_verified")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  bankAccountName    String?            @map("bank_account_name")
  bankAccountNumber  String?            @map("bank_account_number")
  bankIfscCode       String?            @map("bank_ifsc_code")
  gstNumber          String?            @map("gst_number")
  panNumber          String?            @map("pan_number")
  verificationStatus VerificationStatus @default(NOT_SUBMITTED) @map("verification_status")
  agents             Agent[]
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchantServices   MerchantService[]
  promos             Promotion[]
  slots              Slot[]
  verificationDocs   VerificationDoc[]

  @@map("merchant_profiles")
}

model MerchantService {
  id         String          @id @default(cuid())
  merchantId String          @map("merchant_id")
  serviceId  String          @map("service_id")
  price      Float
  isActive   Boolean         @default(true) @map("is_active")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  merchant   MerchantProfile @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  service    Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([merchantId, serviceId])
  @@index([serviceId])
  @@map("merchant_services")
}

model Address {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  label     String    @default("Home")
  line1     String    @map("line_1")
  line2     String?   @map("line_2")
  city      String
  state     String
  zipCode   String    @map("zip_code")
  latitude  Float?
  longitude Float?
  isDefault Boolean   @default(false) @map("is_default")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings  Booking[]

  @@index([userId])
  @@map("addresses")
}

model Booking {
  id                 String        @id @default(cuid())
  bookingNumber      String        @unique @map("booking_number")
  customerId         String        @map("customer_id")
  merchantId         String?       @map("merchant_id")
  addressId          String        @map("address_id")
  status             BookingStatus @default(PENDING)
  paymentStatus      PaymentStatus @default(UNPAID) @map("payment_status")
  subtotal           Float         @default(0)
  tax                Float         @default(0)
  total              Float         @default(0)
  scheduledAt        DateTime      @map("scheduled_at")
  completedAt        DateTime?     @map("completed_at")
  cancelledAt        DateTime?     @map("cancelled_at")
  notes              String?
  cancellationReason String?       @map("cancellation_reason")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  agentId            String?       @map("agent_id")
  items              BookingItem[]
  address            Address       @relation(fields: [addressId], references: [id])
  agent              Agent?        @relation(fields: [agentId], references: [id])
  customer           User          @relation("CustomerBookings", fields: [customerId], references: [id])
  merchant           User?         @relation("MerchantBookings", fields: [merchantId], references: [id])
  review             Review?
  proofOfWorkUrls     String[]      @default([]) @map("proof_of_work_urls")
  completionOtp       String?       @map("completion_otp")
  chat               Chat?

  @@index([customerId])
  @@index([merchantId])
  @@index([status])
  @@index([scheduledAt])
  @@map("bookings")
}

model BookingItem {
  id        String  @id @default(cuid())
  bookingId String  @map("booking_id")
  serviceId String  @map("service_id")
  quantity  Int     @default(1)
  price     Float
  notes     String?
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id])

  @@index([bookingId])
  @@map("booking_items")
}

model Review {
  id              String    @id @default(cuid())
  bookingId       String    @unique @map("booking_id")
  userId          String    @map("user_id")
  rating          Int
  comment         String?
  imageUrls       String[]  @default([]) @map("image_url")
  merchantReply   String?   @map("merchant_reply")
  merchantReplyAt DateTime? @map("merchant_reply_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  booking         Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("reviews")
}

model Agent {
  id              String          @id @default(cuid())
  userId          String          @unique @map("user_id")
  merchantId      String          @map("merchant_id")
  skills          String[]        @default([])
  status          AgentStatus     @default(OFFLINE)
  rating          Float           @default(0)
  isActive        Boolean         @default(true) @map("is_active")
  lastLocationLat Float?          @map("last_location_lat")
  lastLocationLng Float?          @map("last_location_lng")
  lastLocationAt  DateTime?       @map("last_location_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  merchant        MerchantProfile @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  slots           Slot[]

  @@index([merchantId])
  @@map("agents")
}

model Slot {
  id         String          @id @default(cuid())
  merchantId String          @map("merchant_id")
  agentId    String          @map("agent_id")
  date       DateTime        @db.Date
  startTime  String          @map("start_time")
  endTime    String          @map("end_time")
  isBooked   Boolean         @default(false) @map("is_booked")
  createdAt  DateTime        @default(now()) @map("created_at")
  agent      Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  merchant   MerchantProfile @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([agentId])
  @@index([date])
  @@map("slots")
}

model Promotion {
  id            String          @id @default(cuid())
  merchantId    String          @map("merchant_id")
  code          String          @unique
  type          PromoType
  value         Float
  minOrderValue Float?          @map("min_order_value")
  maxDiscount   Float?          @map("max_discount")
  startDate     DateTime        @default(now()) @map("start_date")
  expiryDate    DateTime        @map("expiry_date")
  usageLimit    Int?            @map("usage_limit")
  currentUsage  Int             @default(0) @map("current_usage")
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  merchant      MerchantProfile @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([code])
  @@index([isActive])
  @@map("promotions")
}

model VerificationDoc {
  id         String             @id @default(cuid())
  merchantId String             @map("merchant_id")
  type       DocType
  fileUrl    String             @map("file_url")
  status     VerificationStatus @default(PENDING_REVIEW)
  reviewNote String?            @map("review_note")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")
  merchant   MerchantProfile    @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@map("verification_docs")
}

enum UserRole {
  CUSTOMER
  MERCHANT
  AGENT
  ADMIN
}

enum UserStatus {
  PENDING_VERIFICATION
  ONBOARDING
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum AuthProvider {
  EMAIL
  PHONE
  GOOGLE
  APPLE
}

enum BookingStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REJECTED
  AGENT_ASSIGNED
  EN_ROUTE
  ARRIVED
}

enum VerificationStatus {
  NOT_SUBMITTED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum DocType {
  PAN_CARD
  AADHAAR
  GST_CERTIFICATE
  BUSINESS_LICENSE
  BANK_PROOF
  OTHER
}

enum AgentStatus {
  AVAILABLE
  BUSY
  OFFLINE
  ONLINE
}

enum PromoType {
  PERCENTAGE
  FLAT
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
}

enum NotificationType {
  NEW_ORDER
  ORDER_STATUS
  REVIEW_RECEIVED
  AGENT_UPDATE
  VERIFICATION_UPDATE
  PROMOTION
  SYSTEM
}

// ─── Wallet & Payments ───

model WalletTransaction {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  amount      Float
  type        TransactionType
  status      TransactionStatus @default(COMPLETED)
  description String?
  referenceId String?           @map("reference_id") // E.g., Booking ID
  createdAt   DateTime          @default(now()) @map("created_at")
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("wallet_transactions")
}

enum TransactionType {
  TOPUP
  PAYMENT
  REFUND
  COMMISSION
  WITHDRAWAL
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Admin {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  passwordHash  String     @map("password_hash")
  status        UserStatus @default(ACTIVE)
  lastLoginAt   DateTime?  @map("last_login_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@map("admins")
}
