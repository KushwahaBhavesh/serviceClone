# ─── Server ───
NODE_ENV=development
PORT=3000

# ─── Database ───
DATABASE_URL=postgresql://user:password@localhost:5432/homeservice

# ─── JWT (REQUIRED — no fallbacks) ───
JWT_SECRET=your-strong-secret-min-16-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-16-chars
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── CORS ───
# Comma-separated origins, or * for all
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ─── File Uploads ───
MAX_FILE_SIZE=5242880
UPLOAD_DIR=public/uploads
